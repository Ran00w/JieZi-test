# JieZi-bench environment configuration
# Copy this to .env and fill in your values.

# Cache root for models, BERTScore, etc.
JIEZI_CACHE_ROOT=/media/dpctc/4TB1/lr/cache

# LLM Judge API credentials
JIEZI_JUDGE_API_KEY=your-judge-api-key-here
JIEZI_JUDGE_BASE_URL=https://your-judge-endpoint/v1
JIEZI_JUDGE_MODEL=your-judge-model-name

# Optional: API keys for cloud models (set as needed)
OPENAI_API_KEY=sk-your-key
ANTHROPIC_API_KEY=sk-ant-your-key
